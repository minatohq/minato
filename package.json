{
  "name": "minato",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "vp config",
    "dev:api": "vp run api#dev",
    "dev:dashboard": "vp run dashboard#dev",
    "dev:widget": "vp run widget#dev",
    "build:widget": "vp run widget#build",
    "db:dev:up": "docker compose up -d",
    "db:dev:down": "docker compose down",
    "db:dev:reset": "docker compose down --volumes",
    "db:check": "vp run --filter @repo/db check",
    "db:generate": "vp run --filter @repo/db generate",
    "db:migrate": "vp run --filter @repo/db migrate",
    "db:push": "vp run --filter @repo/db push",
    "db:studio": "vp run --filter @repo/db studio",
    "auth:generate": "vp run api#auth:generate"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^26.0.0",
      "onFail": "download"
    }
  }
}
