{
  "include": ["src"],
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [
      "vite-plus/client",
      "vite-plugin-svgr/client",
      "babel__core",
      "node",
      "react",
      "react-dom"
    ],

    /* Path aliases */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* JSX */
    "jsx": "react-jsx",

    /* Bundler mode */
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  }
}
